# Required for app auth/session middleware and Supabase-backed features
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: newsletter signup (Loops)
LOOPS_API_KEY=

# Optional: Currently Playing card (Spotify)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Optional: GitHub stats card
GITHUB_TOKEN=

# Optional: Lighthouse stats card (without this, API quota is very limited)
PAGESPEED_API_KEY=

# Optional / currently unused in active code paths
# POSTGRES_URL=
